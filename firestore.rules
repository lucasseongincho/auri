// To deploy: firebase deploy --only firestore:rules
// Verify these rules match Firebase Console before deploying.
// Source of truth is this file — any Console changes should be reflected here.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read/write their own data
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId;
    }

    // Invite codes — authenticated users can read (for validation UI)
    // All writes are server-side via Firebase Admin (bypasses rules)
    match /invite_codes/{codeId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }

  }
}
